+  . = 0x80000000;
+
+  .text.init : {
+    *(.text.init)
+    *(.text*)
+  }
+
+  . = ALIGN(0x1000);
+
+  .tohost : {
+    *(.tohost)
+  }
+
+  .data : {
+    *(.data*)
+  }
+
+  .bss : {
+    *(.bss*)
+    *(COMMON)
+  }
+}
